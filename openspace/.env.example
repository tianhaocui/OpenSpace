# ============================================
# OpenSpace Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# ── LLM Model ──────────────────────────────────────────────
# Set your model. Auto-detected from API key if not set.
# OPENSPACE_MODEL=anthropic/claude-opus-4-20250514

# ── API Keys (set ONE) ─────────────────────────────────────

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# ── Custom Endpoint (optional) ─────────────────────────────
# For proxies or self-hosted LLMs.
# OPENSPACE_LLM_API_KEY=sk-xxx
# OPENSPACE_LLM_API_BASE=https://your-proxy/v1

# ── Embedding (optional) ───────────────────────────────────
# Remote embedding API. If not set, uses local model.
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=

# ── Private Deployment ─────────────────────────────────────
# These are set automatically by openspace-setup.
# OPENSPACE_CLOUD_ENABLED=false
# MCP_USE_ANONYMIZED_TELEMETRY=false

# ── Debug ──────────────────────────────────────────────────
# OPENSPACE_DEBUG=true
